# Account label shown in all alerts (e.g. "Live", "Demo", "GoatFunded 1")
ACCOUNT_LABEL=My Account

# MT5 Configuration
MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_server
MT5_PATH=C:\\Program Files\\MetaTrader 5\\terminal64.exe

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Alert Settings
PRICE_CHECK_INTERVAL=5
ENABLE_TRADE_ALERTS=true
ENABLE_ORDER_ALERTS=true
ENABLE_PRICE_ALERTS=true

# Symbols to monitor (comma-separated)
# Common options: Volatility 25/50/75/100 Index, Step Index, Boom 1000 Index, Crash 1000 Index,
# Jump 50/75/100 Index, XAUUSD, WTI, XAGUSD, NAS100, EURUSD, etc.
MONITORED_SYMBOLS=Volatility 25 Index,Volatility 50 Index,Volatility 75 Index,Volatility 100 Index,Step Index,Boom 1000 Index,Crash 1000 Index,Jump 50 Index,Jump 75 Index,Jump 100 Index

# Profit-Taking Suggestions
ENABLE_PROFIT_SUGGESTIONS=true
MIN_PROFIT_FOR_SUGGESTION=10.0
PROFIT_PERCENTAGE_THRESHOLD=5.0

# Auto Break-Even
# Automatically moves SL to entry price when position profit reaches this many pips
ENABLE_AUTO_BREAKEVEN=false
AUTO_BREAKEVEN_PIPS=20.0

# Pending Order Monitoring
ENABLE_PENDING_ORDER_ALERTS=true
PENDING_ORDER_PROXIMITY_PCT=1.0

# Risk Management Alerts
ENABLE_RISK_ALERTS=true
MARGIN_LEVEL_WARNING=150.0
MARGIN_LEVEL_CRITICAL=100.0
MARGIN_ALERT_MIN_BALANCE=25.0
MAX_POSITION_SIZE_PCT=20.0
DAILY_LOSS_LIMIT_PCT=5.0
DAILY_LOSS_LIMIT_AMOUNT=0.0
DRAWDOWN_LIMIT_PCT=10.0

# Daily Performance Summary
ENABLE_DAILY_SUMMARY=true
DAILY_SUMMARY_HOUR=23
DAILY_SUMMARY_MINUTE=0

# Advanced Price Level Features
ENABLE_PRICE_LEVEL_GROUPS=true
ENABLE_DYNAMIC_LEVELS=false
DYNAMIC_LEVELS_TIMEFRAME=16385
DYNAMIC_LEVELS_PERIODS=100
DYNAMIC_LEVELS_MIN_TOUCHES=2
DYNAMIC_LEVELS_TOLERANCE_PCT=0.5
DYNAMIC_LEVELS_AUTO_UPDATE_HOURS=24

# Enhanced Monitoring
ENABLE_CONNECTION_HEALTH_MONITORING=true
CONNECTION_CHECK_INTERVAL=30

# Alert Rate Limiting
ENABLE_ALERT_RATE_LIMITING=true
MAX_ALERTS_PER_MINUTE=10
MAX_ALERTS_PER_HOUR=100

# Alert Grouping/Batching
ENABLE_ALERT_GROUPING=true
ALERT_BATCH_WINDOW_SECONDS=30
ALERT_BATCH_MAX_SIZE=10

# Quiet Hours (suppress non-critical alerts during these hours)
QUIET_HOURS_ENABLED=false
QUIET_HOURS_START_HOUR=22
QUIET_HOURS_START_MINUTE=0
QUIET_HOURS_END_HOUR=8
QUIET_HOURS_END_MINUTE=0

# Trade History & Analytics
ENABLE_TRADE_HISTORY=true
TRADE_HISTORY_DB_PATH=data/trade_history.db
ENABLE_CHARTS=true

# ML-based Profit Suggestions
ENABLE_ML_PROFIT_SUGGESTIONS=true
ML_MIN_TRADES_FOR_LEARNING=10

# Volatility-based Position Sizing
ENABLE_VOLATILITY_POSITION_SIZING=true
VOLATILITY_PERIODS=20

# Advanced Notifications
ENABLE_PRICE_CHARTS_IN_ALERTS=true
PRICE_CHART_PERIODS=50

# Grid / DCA Tracking
# Alert when a new position is added to a symbol that already has open positions,
# showing the updated average entry and total exposure.
ENABLE_GRID_DCA_ALERTS=true

# Correlation Alerts
# Alert when two normally-correlated symbols diverge significantly.
# CORRELATION_PAIRS: colon-separated symbol pairs, comma-separated list
# Example: XAUUSD:XAGUSD,NAS100:US30
ENABLE_CORRELATION_ALERTS=false
CORRELATION_PAIRS=XAUUSD:XAGUSD
CORRELATION_LOOKBACK_BARS=50
CORRELATION_ALERT_THRESHOLD=0.5

# Economic Calendar / News Alerts
# Sends an alert before high-impact events affecting your monitored symbols.
ENABLE_NEWS_ALERTS=true
NEWS_MIN_IMPACT=High
NEWS_ALERT_ADVANCE_MINUTES=15
# Comma-separated currency codes. Leave empty to auto-detect from active positions.
NEWS_CURRENCIES=

# Discord Notifications
ENABLE_DISCORD_NOTIFICATIONS=false
DISCORD_WEBHOOK_URL=

# Email Notifications
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_SENDER_PASSWORD=your_app_password
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com
EMAIL_USE_TLS=true

# Webhook Notifications
ENABLE_WEBHOOK_NOTIFICATIONS=false
WEBHOOK_URL=https://your-webhook-url.com/api/notifications
# Optional: custom headers in JSON format
# Example: {"Authorization": "Bearer token123"}
WEBHOOK_HEADERS=
